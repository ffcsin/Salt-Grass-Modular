---
import BaseLayout from '../components/layout/BaseLayout.astro';
import QuoteRequestForm from '../components/forms/QuoteRequestForm.astro';
import { faqSchema } from '../lib/seo';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Contact', url: '/contact' },
];
const faqs = [
  { q: 'How quickly will I hear back?', a: 'Dylan and the team respond to quote requests within 24 hours. For urgent or government/military deployment needs, call (405) 659-1949 directly.' },
  { q: 'Is a quote free and no-obligation?', a: 'Yes. Requesting a quote is completely free and carries no obligation. We give you transparent, all-in pricing so you can plan with confidence.' },
];
---

<BaseLayout
  title="Contact Saltgrass Modular"
  description="Request a free, no-obligation quote from Saltgrass Modular. Transparent all-in pricing on custom container homes, modular pools, and rapid-deployment housing."
  keywords={['contact Saltgrass Modular', 'modular home quote', 'container home quote Oklahoma']}
  breadcrumbs={breadcrumbs}
  schemas={[faqSchema(faqs)]}
>
  <!-- Hero: prompt (left) + quote form on a white card (right), over brand navy -->
  <section id="contact-hero" class="relative overflow-hidden bg-ink-900 text-white">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-primary/25 via-ink-900 to-ink-900" aria-hidden="true"></div>
    <div class="container relative py-section-y-lg">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left: the pitch -->
        <div>
          <span class="inline-block text-sm font-bold uppercase tracking-wide text-[#fca5a5] mb-4">Let's Talk</span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
            Let's Build Something Together
          </h1>
          <p class="text-lg md:text-xl text-ink-200 leading-relaxed mb-10">
            Tell us about your project — a custom container home, a modular pool, a development, or a
            rapid-deployment need. You'll get transparent, all-in pricing and a reply from Dylan within
            24 hours.
          </p>

          <!-- Contact methods -->
          <div class="space-y-5">
            <a href="tel:+14056591949" class="flex items-start gap-4 group">
              <span class="text-2xl" aria-hidden="true">📞</span>
              <span>
                <span class="block text-white font-semibold group-hover:text-[#fca5a5] transition-colors">(405) 659-1949</span>
                <span class="block text-sm text-ink-300">Monday–Friday, 8am–5pm CST</span>
              </span>
            </a>
            <a href="mailto:Dylan.Walker@saltgrassmodular.com" class="flex items-start gap-4 group">
              <span class="text-2xl" aria-hidden="true">✉️</span>
              <span>
                <span class="block text-white font-semibold group-hover:text-[#fca5a5] transition-colors break-all">Dylan.Walker@saltgrassmodular.com</span>
                <span class="block text-sm text-ink-300">Response within 24 hours</span>
              </span>
            </a>
            <div class="flex items-start gap-4">
              <span class="text-2xl" aria-hidden="true">📍</span>
              <span>
                <span class="block text-white font-semibold">Wagner, Oklahoma</span>
                <span class="block text-sm text-ink-300">15,000 sq ft facility — tours by appointment</span>
              </span>
            </div>
          </div>
        </div>

        <!-- Right: white form card -->
        <div class="bg-white rounded-2xl shadow-xl p-6 md:p-8 lg:p-10">
          <h2 class="text-2xl md:text-3xl font-bold text-ink-900 mb-1">Request a Free Quote</h2>
          <p class="text-ink-600 text-sm mb-6">Transparent all-in pricing. No obligation.</p>
          <QuoteRequestForm />
        </div>
      </div>
    </div>
  </section>

  <!-- Schedule a consultation (LPAI calendar) -->
  <section class="py-section-y bg-ink-50">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-ink-900 mb-4 text-center">Prefer to Schedule a Call?</h2>
        <p class="text-center text-ink-700 mb-8">
          Book a consultation directly and we'll walk you through your options, pricing, and timeline.
        </p>

        <!-- LPAI Calendar Widget -->
        <div class="bg-white rounded-2xl p-8 min-h-96 border-2 border-ink-200 flex items-center justify-center">
          <div class="text-center">
            <p class="text-ink-600 mb-4">🗓️ Calendar booking system integrated with LPAI CRM</p>
            <p class="text-sm text-ink-500">
              The LPAI calendar is live in the admin. Customer-facing booking links and the embedded
              calendar are configured during account setup.
            </p>
            <p class="text-xs text-ink-400 mt-4">
              Location ID: <code class="bg-ink-100 px-2 py-1 rounded">plan_chNIQv7tfy09Ew_h1liV</code>
            </p>
          </div>
        </div>

        <p class="text-center text-ink-600 text-sm mt-6">
          Or call <strong>(405) 659-1949</strong> to book over the phone.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ Quick Links -->
  <section class="py-section-y">
    <div class="container">
      <h2 class="text-3xl font-bold text-ink-900 mb-8 text-center">Quick Answers</h2>
      <div class="max-w-3xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
        <a href="/process" class="bg-white rounded-xl border border-ink-200 p-6 hover:shadow-large hover:border-brand-primary transition">
          <h3 class="font-bold text-ink-900 mb-2">How does the process work?</h3>
          <p class="text-sm text-ink-600">See our 8-stage timeline →</p>
        </a>
        <a href="/saltgrass-101/cost-breakdown" class="bg-white rounded-xl border border-ink-200 p-6 hover:shadow-large hover:border-brand-primary transition">
          <h3 class="font-bold text-ink-900 mb-2">What does it cost?</h3>
          <p class="text-sm text-ink-600">See transparent pricing →</p>
        </a>
        <a href="/services" class="bg-white rounded-xl border border-ink-200 p-6 hover:shadow-large hover:border-brand-primary transition">
          <h3 class="font-bold text-ink-900 mb-2">What services do you offer?</h3>
          <p class="text-sm text-ink-600">Explore our services →</p>
        </a>
        <a href="/about" class="bg-white rounded-xl border border-ink-200 p-6 hover:shadow-large hover:border-brand-primary transition">
          <h3 class="font-bold text-ink-900 mb-2">Tell me about Saltgrass</h3>
          <p class="text-sm text-ink-600">Meet Dylan and the team →</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
