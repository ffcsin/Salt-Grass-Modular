---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
---

<BaseLayout
  title="Modular Housing for Developers - SaltGrass Modular"
  description="Scale modular housing for residential developments, government contracts, and multi-unit projects. Volume pricing, proven timelines, government-ready."
  keywords="modular development, developer solutions, multi-unit housing, volume production"
>
  <Hero
    eyebrow="For Developers & Government"
    headline="Scale Modular Housing for Your Projects"
    subhead="Volume production. Proven timelines. Transparent pricing. From 10 units to 1,000+ — SaltGrass delivers predictable quality at scale."
    image="/img/projects/modular-container-yoga-studio-glass-a-frame.webp"
  />

  <!-- Why Developers Choose Modular -->
  <section class="py-section-y">
    <div class="container">
      <div class="max-w-3xl mx-auto mb-12 text-center">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Why Developers Choose Modular</h2>
        <p class="text-lg text-ink-700 leading-relaxed">
          Time-to-market matters. Quality matters. Budget certainty matters. Modular construction delivers on all three—at scale.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto mb-12">
        <div class="flex gap-6 items-start">
          <div class="text-5xl flex-shrink-0">⚡</div>
          <div>
            <h3 class="text-2xl font-bold text-ink-900 mb-2">30% Faster to Market</h3>
            <p class="text-ink-700">
              Factory work happens in parallel with site prep and permitting. Compress your timeline and reduce carrying costs.
            </p>
          </div>
        </div>

        <div class="flex gap-6 items-start">
          <div class="text-5xl flex-shrink-0">💰</div>
          <div>
            <h3 class="text-2xl font-bold text-ink-900 mb-2">Predictable Costs</h3>
            <p class="text-ink-700">
              No surprise change orders. Transparent pricing. Volume discounts for large projects. All-in quotes including delivery and installation.
            </p>
          </div>
        </div>

        <div class="flex gap-6 items-start">
          <div class="text-5xl flex-shrink-0">✓</div>
          <div>
            <h3 class="text-2xl font-bold text-ink-900 mb-2">Quality Assurance</h3>
            <p class="text-ink-700">
              Factory-built consistency. Every module inspected and tested before delivery. Zero field defects. Warranty-backed quality.
            </p>
          </div>
        </div>

        <div class="flex gap-6 items-start">
          <div class="text-5xl flex-shrink-0">🎯</div>
          <div>
            <h3 class="text-2xl font-bold text-ink-900 mb-2">Logistical Mastery</h3>
            <p class="text-ink-700">
              Our own delivery fleet. Nationwide coordination. Multi-unit deployments. On-time delivery is our standard.
            </p>
          </div>
        </div>
      </div>

      <div class="bg-brand-primary-50 rounded-2xl p-8 text-center">
        <p class="text-ink-700 mb-4">
          <strong>50+ completed projects</strong> — from single-family developments to government contracts to disaster relief deployments.
        </p>
        <p class="text-ink-700">
          <strong>99% client satisfaction</strong> with on-time delivery and zero quality issues.
        </p>
      </div>
    </div>
  </section>

  <!-- Market Segments We Serve -->
  <section class="py-section-y bg-ink-50">
    <div class="container">
      <h2 class="text-4xl font-bold text-ink-900 mb-12 text-center">Who We Serve</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <div class="bg-white rounded-2xl p-8 shadow-soft">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">🏢 Residential Developers</h3>
          <p class="text-ink-700 mb-6">
            Multi-unit residential projects, subdivisions, and apartment-style communities. Modular accelerates time-to-market and reduces on-site disruption.
          </p>
          <ul class="space-y-2 text-sm text-ink-700">
            <li>• 10–1,000+ unit projects</li>
            <li>• Standardized or custom layouts</li>
            <li>• Volume discounts available</li>
            <li>• Coordination with infrastructure</li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-soft">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">🛡️ Military & Government</h3>
          <p class="text-ink-700 mb-6">
            Base housing, rapid response facilities, and government RFPs. GSA-certified, spec-compliant, contract-ready.
          </p>
          <ul class="space-y-2 text-sm text-ink-700">
            <li>• Military-grade construction</li>
            <li>• GSA schedule available</li>
            <li>• Government contract experience</li>
            <li>• Rapid deployment capability</li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-soft">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">🏠 Real Estate Investors</h3>
          <p class="text-ink-700 mb-6">
            Rental portfolios, ADU projects, and investment properties. Fast construction = faster cash flow.
          </p>
          <ul class="space-y-2 text-sm text-ink-700">
            <li>• Rental-spec finishes</li>
            <li>• Fast deployment</li>
            <li>• Multi-unit financing coordination</li>
            <li>• Flexible customization</li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-soft">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">🏫 Education & Institutions</h3>
          <p class="text-ink-700 mb-6">
            Dorms, staff housing, and research facilities. Scalable, code-compliant, education-ready.
          </p>
          <ul class="space-y-2 text-sm text-ink-700">
            <li>• Institutional specifications</li>
            <li>• Large-scale coordination</li>
            <li>• Phased construction possible</li>
            <li>• Future modifications easy</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- RFQ Process -->
  <section class="py-section-y">
    <div class="container">
      <div class="max-w-3xl mx-auto mb-12 text-center">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">The RFQ Process</h2>
        <p class="text-lg text-ink-700">
          From initial scope call to project delivery — transparent, predictable, collaborative.
        </p>
      </div>

      <div class="max-w-3xl mx-auto space-y-6">
        <div class="flex gap-6 items-start">
          <div class="w-12 h-12 rounded-full bg-brand-primary text-white flex items-center justify-center font-bold flex-shrink-0">1</div>
          <div>
            <h3 class="text-xl font-bold text-ink-900 mb-2">Initial Scope Call</h3>
            <p class="text-ink-700">
              We discuss your project: unit count, specifications, timeline, location, and budget. 30–60 minutes with Dylan or our project manager.
            </p>
          </div>
        </div>

        <div class="flex gap-6 items-start">
          <div class="w-12 h-12 rounded-full bg-brand-primary text-white flex items-center justify-center font-bold flex-shrink-0">2</div>
          <div>
            <h3 class="text-xl font-bold text-ink-900 mb-2">Detailed RFQ Submission</h3>
            <p class="text-ink-700">
              You provide site plans, unit specs, delivery timeline, and compliance requirements. We respond with detailed cost estimate and production schedule.
            </p>
          </div>
        </div>

        <div class="flex gap-6 items-start">
          <div class="w-12 h-12 rounded-full bg-brand-primary text-white flex items-center justify-center font-bold flex-shrink-0">3</div>
          <div>
            <h3 class="text-xl font-bold text-ink-900 mb-2">Negotiation & Contract</h3>
            <p class="text-ink-700">
              We refine terms: unit pricing, delivery schedule, payment plan, and special requirements. Contract is transparent and binding.
            </p>
          </div>
        </div>

        <div class="flex gap-6 items-start">
          <div class="w-12 h-12 rounded-full bg-brand-primary text-white flex items-center justify-center font-bold flex-shrink-0">4</div>
          <div>
            <h3 class="text-xl font-bold text-ink-900 mb-2">Design & Engineering</h3>
            <p class="text-ink-700">
              Our team finalizes designs, specifications, and compliance documentation. Yours for review and approval. Iterations as needed.
            </p>
          </div>
        </div>

        <div class="flex gap-6 items-start">
          <div class="w-12 h-12 rounded-full bg-brand-primary text-white flex items-center justify-center font-bold flex-shrink-0">5</div>
          <div>
            <h3 class="text-xl font-bold text-ink-900 mb-2">Fabrication & Delivery</h3>
            <p class="text-ink-700">
              Production begins. Regular updates on progress. Modules delivered per agreed schedule. Installation coordination provided.
            </p>
          </div>
        </div>
      </div>

      <div class="bg-brand-primary text-white rounded-2xl p-8 text-center mt-12">
        <h3 class="text-2xl font-bold mb-4">Typical Timeline</h3>
        <p class="text-lg opacity-90">
          From initial call to first module delivery: 6–12 weeks (depending on design complexity and fabrication volume)
        </p>
      </div>
    </div>
  </section>

  <!-- Competitive Advantages -->
  <section class="py-section-y bg-ink-50">
    <div class="container">
      <h2 class="text-4xl font-bold text-ink-900 mb-12 text-center">Why SaltGrass Wins</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl p-8 shadow-soft">
          <h3 class="text-lg font-bold text-ink-900 mb-3">Proven Capacity</h3>
          <p class="text-ink-700">
            Our 15,000+ SF Oklahoma facility handles volume production without sacrificing quality. Experienced team coordinating large-scale projects.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-soft">
          <h3 class="text-lg font-bold text-ink-900 mb-3">Transparent Pricing</h3>
          <p class="text-ink-700">
            No hidden fees. All-in quotes including delivery & installation. Volume discounts available. Detailed cost breakdowns.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-soft">
          <h3 class="text-lg font-bold text-ink-900 mb-3">Government Experience</h3>
          <p class="text-ink-700">
            GSA-certified, contract experience, and compliance expertise. We speak government RFP language. Partner with agencies nationwide.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-soft">
          <h3 class="text-lg font-bold text-ink-900 mb-3">Design Flexibility</h3>
          <p class="text-ink-700">
            Modular designs are customizable. Standard units or unique specs. Phased production possible. Adapt to changing project needs.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-soft">
          <h3 class="text-lg font-bold text-ink-900 mb-3">Logistics Mastery</h3>
          <p class="text-ink-700">
            Own delivery fleet. Nationwide experience. Coordinate multi-unit deployments. On-time delivery is our standard.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-soft">
          <h3 class="text-lg font-bold text-ink-900 mb-3">Long-Term Partnership</h3>
          <p class="text-ink-700">
            We're not just a vendor. Dylan's vision is building long-term relationships. Support during and after delivery. Ongoing service options.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Commercial & Creative Builds -->
  <section class="py-section-y bg-ink-50">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Beyond Homes: Commercial &amp; Creative Builds</h2>
        <p class="text-lg text-ink-700 leading-relaxed">
          Modular construction isn't just for housing. Restaurants, retail, hospitality, and studio
          spaces — if it can be built, it can be built modular. Here's a look at what's possible.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-2xl shadow-soft overflow-hidden">
          <img src="/img/projects/modular-container-restaurant-oklahoma-city-rendering.webp" alt="Multi-container modular restaurant concept, Oklahoma City" loading="lazy" class="h-44 w-full object-cover" />
          <div class="p-5"><h3 class="font-bold text-ink-900">Restaurants</h3><p class="text-sm text-ink-700 mt-1">Multi-container dining with rooftop decks.</p></div>
        </div>
        <div class="bg-white rounded-2xl shadow-soft overflow-hidden">
          <img src="/img/projects/20-ft-shipping-container-bar-outdoor.webp" alt="Outdoor shipping-container bar build" loading="lazy" class="h-44 w-full object-cover" />
          <div class="p-5"><h3 class="font-bold text-ink-900">Bars &amp; Taprooms</h3><p class="text-sm text-ink-700 mt-1">Turnkey 20' container bars for venues.</p></div>
        </div>
        <div class="bg-white rounded-2xl shadow-soft overflow-hidden">
          <img src="/img/projects/container-coffee-shop-interior-espresso-bar.webp" alt="Container coffee shop interior with espresso bar" loading="lazy" class="h-44 w-full object-cover" />
          <div class="p-5"><h3 class="font-bold text-ink-900">Coffee &amp; Retail</h3><p class="text-sm text-ink-700 mt-1">Drive-up kiosks and full retail fit-outs.</p></div>
        </div>
        <div class="bg-white rounded-2xl shadow-soft overflow-hidden">
          <img src="/img/projects/modular-container-yoga-studio-glass-a-frame.webp" alt="Glass A-frame modular yoga and fitness studio" loading="lazy" class="h-44 w-full object-cover" />
          <div class="p-5"><h3 class="font-bold text-ink-900">Studios &amp; Wellness</h3><p class="text-sm text-ink-700 mt-1">Glass A-frame studios and fitness spaces.</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Study Highlight -->
  <section class="py-section-y">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-4xl font-bold text-ink-900 mb-8 text-center">Recent Project Highlight</h2>

        <div class="bg-gradient-to-br from-indigo-100 to-indigo-200 rounded-2xl p-8 md:p-12">
          <div class="flex gap-4 items-start mb-6">
            <span class="text-5xl">🏗️</span>
            <div>
              <h3 class="text-2xl font-bold text-indigo-900 mb-2">12-Unit Multi-Family Development</h3>
              <p class="text-indigo-800">Oklahoma</p>
            </div>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
            <div class="bg-white rounded-lg p-4 text-center">
              <p class="text-sm text-indigo-600 font-semibold">Units</p>
              <p class="text-2xl font-bold text-indigo-900">12</p>
            </div>
            <div class="bg-white rounded-lg p-4 text-center">
              <p class="text-sm text-indigo-600 font-semibold">Size Each</p>
              <p class="text-2xl font-bold text-indigo-900">640 SF</p>
            </div>
            <div class="bg-white rounded-lg p-4 text-center">
              <p class="text-sm text-indigo-600 font-semibold">Timeline</p>
              <p class="text-2xl font-bold text-indigo-900">14 mo</p>
            </div>
            <div class="bg-white rounded-lg p-4 text-center">
              <p class="text-sm text-indigo-600 font-semibold">Occupancy</p>
              <p class="text-2xl font-bold text-indigo-900">100%</p>
            </div>
          </div>

          <p class="text-indigo-900 leading-relaxed">
            "SaltGrass delivered exactly what we needed: predictable timeline, transparent pricing, and zero quality issues. Perfect partner for modular development."
          </p>
          <p class="text-indigo-800 font-semibold mt-4">— Residential Developer</p>
        </div>

        <div class="text-center mt-12">
          <a href="/projects" class="btn-secondary">View All Case Studies</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-section-y bg-ink-50">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-4xl font-bold text-ink-900 mb-12 text-center">Developer Questions</h2>

        <div class="space-y-4">
          <details class="bg-white rounded-lg p-6 group">
            <summary class="cursor-pointer font-bold text-ink-900 flex items-center justify-between">
              What's your minimum project size?
              <span class="text-2xl group-open:rotate-180 transition">▼</span>
            </summary>
            <p class="text-ink-700 mt-4">
              No minimum. We've handled single-unit projects and 1,000+ unit deployments. Pricing scales with volume. Let's discuss your specific project.
            </p>
          </details>

          <details class="bg-white rounded-lg p-6 group">
            <summary class="cursor-pointer font-bold text-ink-900 flex items-center justify-between">
              How do you handle phased delivery?
              <span class="text-2xl group-open:rotate-180 transition">▼</span>
            </summary>
            <p class="text-ink-700 mt-4">
              Phased production is our strength. We coordinate fabrication batches with your site prep schedule. Units delivered as needed to match your timeline.
            </p>
          </details>

          <details class="bg-white rounded-lg p-6 group">
            <summary class="cursor-pointer font-bold text-ink-900 flex items-center justify-between">
              Can you accommodate custom specifications?
              <span class="text-2xl group-open:rotate-180 transition">▼</span>
            </summary>
            <p class="text-ink-700 mt-4">
              Absolutely. Military specs, government compliance, institutional requirements — we build to your exact standards. Pricing adjusts accordingly.
            </p>
          </details>

          <details class="bg-white rounded-lg p-6 group">
            <summary class="cursor-pointer font-bold text-ink-900 flex items-center justify-between">
              What about warranty and support?
              <span class="text-2xl group-open:rotate-180 transition">▼</span>
            </summary>
            <p class="text-ink-700 mt-4">
              1-year comprehensive warranty on all units. Extended warranties available. Our team provides installation support and post-delivery service options.
            </p>
          </details>

          <details class="bg-white rounded-lg p-6 group">
            <summary class="cursor-pointer font-bold text-ink-900 flex items-center justify-between">
              Are you available for government RFPs?
              <span class="text-2xl group-open:rotate-180 transition">▼</span>
            </summary>
            <p class="text-ink-700 mt-4">
              Yes. We're GSA-certified and have experience with government contracting. Send us your RFP and we'll respond with a detailed proposal.
            </p>
          </details>
        </div>

        <div class="mt-12 text-center">
          <p class="text-ink-700 mb-6 font-semibold">Ready to discuss your project?</p>
          <a href="/contact" class="btn-primary">Submit Your RFQ</a>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner
    headline="Ready to Discuss Your Project?"
    subhead="Submit your RFQ or schedule a developer call with Dylan to explore volume modular solutions."
  />
</BaseLayout>
