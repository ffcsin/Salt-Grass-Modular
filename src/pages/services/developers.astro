---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
---

<BaseLayout
  title="Developers & Military Solutions - Saltgrass Modular"
  description="B2B modular housing for developers, volume projects, and military contracts. Scalable, transparent RFQ process, government-ready."
>
  <Hero
    eyebrow="B2B Solutions"
    headline="Scalable Modular Housing for Developers & Government"
    subhead="Volume production, proven timelines, government contracts, and transparent RFQ process. From 10 units to 1,000+."
    image="/img/developers-hero.jpg"
  />

  <!-- Service Overview -->
  <section class="py-section-y">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-16">
        <div>
          <h2 class="text-4xl font-bold text-ink-900 mb-6">Scale Modular Housing for Your Projects</h2>
          <p class="text-lg text-ink-700 mb-4 leading-relaxed">
            Saltgrass partners with residential developers, military branches, government agencies, and real estate investors who need scalable, reliable modular housing solutions.
          </p>
          <p class="text-lg text-ink-700 mb-6 leading-relaxed">
            Whether you're building a 50-unit residential development, outfitting a military base, or responding to a government RFP, we deliver:
          </p>
          <ul class="space-y-3">
            <li class="flex gap-3">
              <span class="text-brand-primary font-bold text-lg">✓</span>
              <span class="text-ink-700">Predictable timelines & transparent costs</span>
            </li>
            <li class="flex gap-3">
              <span class="text-brand-primary font-bold text-lg">✓</span>
              <span class="text-ink-700">Volume pricing & flexibility</span>
            </li>
            <li class="flex gap-3">
              <span class="text-brand-primary font-bold text-lg">✓</span>
              <span class="text-ink-700">Government & military compliance</span>
            </li>
            <li class="flex gap-3">
              <span class="text-brand-primary font-bold text-lg">✓</span>
              <span class="text-ink-700">Logistical coordination & on-time delivery</span>
            </li>
            <li class="flex gap-3">
              <span class="text-brand-primary font-bold text-lg">✓</span>
              <span class="text-ink-700">Dedicated project management</span>
            </li>
          </ul>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-xl h-96 md:h-full">
          <img
            src="/img/development-project.jpg"
            alt="Large-scale modular development project"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Market Segments -->
  <section class="py-section-y bg-ink-50">
    <div class="container">
      <h2 class="text-4xl font-bold text-ink-900 mb-12 text-center">Who We Serve</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl p-8 shadow-soft hover:shadow-large transition">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Residential Developers</h3>
          <p class="text-ink-700 mb-6">
            Multi-unit residential projects, subdivisions, and apartment-style communities. Modular accelerates time-to-market and reduces on-site disruption.
          </p>
          <ul class="space-y-2 text-sm text-ink-700">
            <li>• 10–1,000+ unit projects</li>
            <li>• Standardized or custom layouts</li>
            <li>• Volume discounts available</li>
            <li>• Coordination with infrastructure</li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-soft hover:shadow-large transition">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Military & Government</h3>
          <p class="text-ink-700 mb-6">
            Base housing, temporary deployments, rapid response facilities, and government RFPs. GSA-certified, spec-compliant, contract-ready.
          </p>
          <ul class="space-y-2 text-sm text-ink-700">
            <li>• Military-grade construction</li>
            <li>• GSA schedule available</li>
            <li>• Government contract experience</li>
            <li>• Rapid deployment capability</li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-soft hover:shadow-large transition">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Real Estate Investors</h3>
          <p class="text-ink-700 mb-6">
            Rental portfolios, ADU projects, and investment properties. Fast construction = faster cash flow. Modular reduces vacancy time.
          </p>
          <ul class="space-y-2 text-sm text-ink-700">
            <li>• Rental-spec finishes</li>
            <li>• Fast deployment</li>
            <li>• Multi-unit financing coordination</li>
            <li>• Flexible customization</li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-soft hover:shadow-large transition">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Education & Institutions</h3>
          <p class="text-ink-700 mb-6">
            Dorms, staff housing, research facilities, and temporary campus facilities. Scalable, code-compliant, and education-ready.
          </p>
          <ul class="space-y-2 text-sm text-ink-700">
            <li>• Institutional specifications</li>
            <li>• Large-scale coordination</li>
            <li>• Phased construction possible</li>
            <li>• Future modifications easy</li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-soft hover:shadow-large transition">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Infrastructure & Workforce</h3>
          <p class="text-ink-700 mb-6">
            Temporary worker housing for construction, oil & gas, mining, and infrastructure projects. On-site assembly, rapid deployment.
          </p>
          <ul class="space-y-2 text-sm text-ink-700">
            <li>• Worker camp configurations</li>
            <li>• Scalable with project phases</li>
            <li>• Remote location delivery</li>
            <li>• Custom amenity options</li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-soft hover:shadow-large transition">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Disaster & Emergency Response</h3>
          <p class="text-ink-700 mb-6">
            FEMA-eligible temporary housing, emergency shelters, and rapid response deployments. Government partnership-ready.
          </p>
          <ul class="space-y-2 text-sm text-ink-700">
            <li>• FEMA-approved housing</li>
            <li>• Emergency deployment specs</li>
            <li>• Government coordination</li>
            <li>• Rapid logistics</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- RFQ Process -->
  <section class="py-section-y">
    <div class="container">
      <h2 class="text-4xl font-bold text-ink-900 mb-12 text-center">The RFQ Process</h2>

      <div class="max-w-3xl mx-auto mb-12">
        <div class="space-y-6">
          <div class="flex gap-6">
            <div class="bg-brand-primary text-white rounded-full w-12 h-12 flex-shrink-0 flex items-center justify-center font-bold text-lg">1</div>
            <div>
              <h3 class="text-xl font-bold text-ink-900 mb-2">Initial Scope Call</h3>
              <p class="text-ink-700">
                We discuss your project: unit count, specifications, timeline, location, and budget. 30–60 minutes with Dylan or our project manager.
              </p>
            </div>
          </div>

          <div class="flex gap-6">
            <div class="bg-brand-primary text-white rounded-full w-12 h-12 flex-shrink-0 flex items-center justify-center font-bold text-lg">2</div>
            <div>
              <h3 class="text-xl font-bold text-ink-900 mb-2">Detailed RFQ Submission</h3>
              <p class="text-ink-700">
                You provide: site plans, unit specifications, delivery timeline, and any compliance requirements. We respond with a detailed cost estimate and production schedule.
              </p>
            </div>
          </div>

          <div class="flex gap-6">
            <div class="bg-brand-primary text-white rounded-full w-12 h-12 flex-shrink-0 flex items-center justify-center font-bold text-lg">3</div>
            <div>
              <h3 class="text-xl font-bold text-ink-900 mb-2">Negotiation & Contract</h3>
              <p class="text-ink-700">
                We refine terms: unit pricing, delivery schedule, payment plan, and any special requirements. Contract is transparent and binding.
              </p>
            </div>
          </div>

          <div class="flex gap-6">
            <div class="bg-brand-primary text-white rounded-full w-12 h-12 flex-shrink-0 flex items-center justify-center font-bold text-lg">4</div>
            <div>
              <h3 class="text-xl font-bold text-ink-900 mb-2">Design & Engineering</h3>
              <p class="text-ink-700">
                Our team finalizes designs, specifications, and compliance documentation. Yours for review and approval. Iterations as needed.
              </p>
            </div>
          </div>

          <div class="flex gap-6">
            <div class="bg-brand-primary text-white rounded-full w-12 h-12 flex-shrink-0 flex items-center justify-center font-bold text-lg">5</div>
            <div>
              <h3 class="text-xl font-bold text-ink-900 mb-2">Fabrication & Delivery</h3>
              <p class="text-ink-700">
                Production begins. You receive regular updates on progress. Modules are delivered per agreed schedule. Installation coordination provided.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-brand-primary text-white rounded-2xl p-8 text-center">
        <h3 class="text-2xl font-bold mb-4">Typical RFQ Timeline</h3>
        <p class="text-lg mb-6 opacity-90">
          From initial call to first module delivery: 6–12 weeks, depending on design complexity and fabrication volume.
        </p>
      </div>
    </div>
  </section>

  <!-- Competitive Advantages -->
  <section class="py-section-y bg-ink-50">
    <div class="container">
      <h2 class="text-4xl font-bold text-ink-900 mb-12 text-center">Why Choose Saltgrass for Volume Projects</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl p-6">
          <h3 class="text-lg font-bold text-ink-900 mb-3">Proven Capacity</h3>
          <p class="text-ink-700">
            Our 15,000+ SF Oklahoma facility handles volume production without sacrificing quality. Experienced team coordinating large-scale projects.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-6">
          <h3 class="text-lg font-bold text-ink-900 mb-3">Transparent Pricing</h3>
          <p class="text-ink-700">
            No hidden fees. All-in quotes including delivery & installation. Volume discounts available. Detailed cost breakdowns.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-6">
          <h3 class="text-lg font-bold text-ink-900 mb-3">Government Experience</h3>
          <p class="text-ink-700">
            GSA-certified, contract experience, and compliance expertise. We speak government RFP language. Partner with agencies nationwide.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-6">
          <h3 class="text-lg font-bold text-ink-900 mb-3">Flexibility</h3>
          <p class="text-ink-700">
            Modular designs are customizable. Standard units or unique specs. Phased production possible. Adapt to changing project needs.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-6">
          <h3 class="text-lg font-bold text-ink-900 mb-3">Logistics Mastery</h3>
          <p class="text-ink-700">
            Own delivery fleet. Nationwide experience. Coordinate multi-unit deployments. On-time delivery is our standard.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-6">
          <h3 class="text-lg font-bold text-ink-900 mb-3">Long-Term Partnership</h3>
          <p class="text-ink-700">
            We're not just a vendor. Dylan's vision is building long-term relationships. Support during and after delivery. Ongoing service options.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact for Developers -->
  <CtaBanner
    headline="Ready to Discuss Your Project?"
    subhead="Submit your RFQ or schedule a developer call with Dylan to explore volume modular solutions."
  />
</BaseLayout>
