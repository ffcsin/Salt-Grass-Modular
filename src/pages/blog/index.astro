---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getBlogPosts, getBlogCategories, getAuthorName, estimateReadTime } from '../../lib/blog';

const [posts, categories] = await Promise.all([
  getBlogPosts(),
  getBlogCategories(),
]);

const featured = posts.find(p => p.heroStyle === 'featured') || posts[0];
const rest = posts.filter(p => p._id !== featured?._id);

const fallbackCats = Array.from(
  new Set(posts.map(p => p.category).filter(Boolean) as string[]),
).map(name => ({ slug: name, name, postCount: posts.filter(p => p.category === name).length }));
const cats = categories.length > 0 ? categories : fallbackCats;
---

<BaseLayout
  title="Blog - Saltgrass Modular"
  description="Industry insights, guides, and stories about modular construction."
  keywords="modular construction, container homes, blog"
>

  <section class="bg-brand-primary text-white py-section-y">
    <div class="container text-center">
      <h1 class="text-5xl md:text-6xl font-bold mb-4">
        <span class="text-brand-primary-50">Saltgrass</span> Blog
      </h1>
      <p class="text-lg text-brand-primary-100 max-w-2xl mx-auto">
        Tips, guides, and industry insights about modular construction.
      </p>
    </div>
  </section>

  <section class="py-section-y bg-white">
    <div class="container">
      {posts.length === 0 ? (
        <div class="text-center py-12">
          <div class="text-5xl mb-4">📝</div>
          <h2 class="text-ink-900 text-xl mb-2 font-bold">Blog Coming Soon</h2>
          <p class="text-ink-600">We're working on great content. Check back soon!</p>
        </div>
      ) : (
        <>
          {(cats.length > 0 || posts.length > 6) && (
            <div class="mb-8 space-y-4">
              <input id="blog-search" type="search" placeholder="Search articles…"
                class="w-full max-w-md px-4 py-2.5 border-2 border-ink-200 rounded-lg text-sm focus:outline-none focus:border-brand-primary" />
              {cats.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  <button data-cat="" class="cat-pill px-3 py-1.5 rounded-full text-sm bg-brand-primary text-white font-medium transition">All</button>
                  {cats.map(c => (
                    <button data-cat={c.slug} class="cat-pill px-3 py-1.5 rounded-full text-sm bg-white border-2 border-ink-200 text-ink-900 hover:border-brand-primary transition">
                      {c.name}{c.postCount != null ? ` (${c.postCount})` : ''}
                    </button>
                  ))}
                </div>
              )}
            </div>
          )}

          {featured && (
            <a href={`/blog/${featured.slug}`} class="block mb-12 group">
              <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 bg-white rounded-2xl shadow-large hover:shadow-xl transition overflow-hidden">
                {featured.coverImage && (
                  <img src={featured.coverImage} alt={featured.title}
                    width="800" height="450" loading="eager" fetchpriority="high"
                    class="w-full h-64 lg:h-full object-cover" />
                )}
                <div class="p-8 flex flex-col justify-center">
                  <div class="inline-flex w-fit mb-3 px-3 py-1 rounded-full bg-brand-primary text-white text-xs font-bold uppercase tracking-wide">
                    {featured.category || 'Featured'}
                  </div>
                  <h2 class="text-ink-900 text-3xl font-bold mb-3 group-hover:text-brand-primary transition">{featured.title}</h2>
                  <p class="text-ink-700 mb-4 leading-relaxed">{featured.excerpt}</p>
                  <div class="text-sm text-ink-600">
                    {getAuthorName(featured.author)} · {new Date(featured.publishedAt).toLocaleDateString()} · {estimateReadTime(featured.content, featured.excerpt)} min read
                  </div>
                </div>
              </div>
            </a>
          )}

          <div id="blog-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {rest.map(post => (
              <a href={`/blog/${post.slug}`} class="card group post-row" data-cat={post.category || ''} data-title={post.title.toLowerCase()} data-excerpt={(post.excerpt || '').toLowerCase()}>
                {post.coverImage && (
                  <img src={post.coverImage} alt={post.title}
                    width="800" height="450" loading="lazy"
                    class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300" />
                )}
                <div class="p-6">
                  {post.category && <div class="inline-block mb-2 px-2 py-1 rounded-full bg-brand-primary-50 text-brand-primary text-xs font-bold uppercase tracking-wide">{post.category}</div>}
                  <h3 class="text-ink-900 font-bold mb-2 group-hover:text-brand-primary transition line-clamp-2">{post.title}</h3>
                  <p class="text-ink-700 text-sm mb-3 line-clamp-2">{post.excerpt}</p>
                  <div class="text-xs text-ink-600">
                    {new Date(post.publishedAt).toLocaleDateString()} · {estimateReadTime(post.content, post.excerpt)} min read
                  </div>
                </div>
              </a>
            ))}
          </div>

          <div id="blog-empty" class="hidden text-center py-12 text-ink-600">
            No articles match your filters.
          </div>
        </>
      )}
    </div>
  </section>

  <script>
    function initBlogFilters() {
      const pills = document.querySelectorAll<HTMLButtonElement>('.cat-pill');
      const rows = document.querySelectorAll<HTMLElement>('.post-row');
      const search = document.getElementById('blog-search') as HTMLInputElement | null;
      const empty = document.getElementById('blog-empty');
      if (pills.length === 0 && !search) return;

      let activeCat = '';
      let query = '';

      const apply = () => {
        let visible = 0;
        rows.forEach(row => {
          const cat = row.getAttribute('data-cat') || '';
          const title = row.getAttribute('data-title') || '';
          const excerpt = row.getAttribute('data-excerpt') || '';
          const matchesCat = !activeCat || cat === activeCat;
          const matchesQuery = !query || title.includes(query) || excerpt.includes(query);
          const show = matchesCat && matchesQuery;
          row.classList.toggle('hidden', !show);
          if (show) visible++;
        });
        empty?.classList.toggle('hidden', visible > 0);
      };

      pills.forEach(btn => {
        btn.addEventListener('click', () => {
          activeCat = btn.getAttribute('data-cat') || '';
          pills.forEach(p => {
            const isActive = p === btn;
            p.className = isActive
              ? 'cat-pill px-3 py-1.5 rounded-full text-sm bg-brand-primary text-white font-medium transition'
              : 'cat-pill px-3 py-1.5 rounded-full text-sm bg-white border-2 border-ink-200 text-ink-900 hover:border-brand-primary transition';
          });
          apply();
        });
      });

      search?.addEventListener('input', () => {
        query = (search.value || '').toLowerCase().trim();
        apply();
      });
    }
    document.addEventListener('astro:page-load', initBlogFilters);
    initBlogFilters();
  </script>
</BaseLayout>
