---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { COMPARISONS } from '../../data/comparisons';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Guides & Comparisons', url: '/compare' },
];
const comparisons = [...COMPARISONS].sort((a, b) => a.title.localeCompare(b.title));
---

<BaseLayout
  title="Guides & Comparisons — Modular Construction Decisions"
  description="Honest side-by-side comparisons to help you choose: container vs. traditional, modular vs. manufactured, pool types, and more. From Saltgrass Modular."
  keywords={['modular construction comparison', 'container homes vs traditional', 'modular vs manufactured']}
  breadcrumbs={breadcrumbs}
>
  <section class="py-section-y-lg bg-ink-50">
    <div class="container max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-bold text-ink-900 mb-4">Guides & Comparisons</h1>
      <p class="text-lg text-ink-700 leading-relaxed max-w-2xl">
        Choosing how to build is a big decision. These honest side-by-side comparisons lay out the real
        trade-offs — no strawmen, no sales spin.
      </p>
    </div>
  </section>

  <section class="py-section-y">
    <div class="container max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {comparisons.map((c) => (
          <a href={`/compare/${c.slug}`} class="block rounded-2xl border border-ink-200 bg-white p-8 hover:border-brand-primary hover:shadow-large transition group">
            <h2 class="text-xl font-bold text-ink-900 mb-2 group-hover:text-brand-primary transition-colors">{c.title}</h2>
            <p class="text-ink-700 text-sm leading-relaxed">{c.description}</p>
            <span class="btn-ghost mt-4 inline-flex">Read comparison →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner
    headline="Still weighing your options?"
    subhead="Talk to Dylan for an honest recommendation tailored to your project and budget."
  />
</BaseLayout>
