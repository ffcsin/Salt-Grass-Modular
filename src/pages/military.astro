---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
---

<BaseLayout
  title="Military & Government Housing Solutions - Saltgrass Modular"
  description="FEMA-approved, GSA-certified modular housing for military bases, government agencies, and rapid deployment. Spec-compliant, contract-ready."
  keywords="military housing, government contracts, FEMA approved, GSA certified, rapid deployment"
>
  <Hero
    eyebrow="Military & Government"
    headline="Modular Housing for Defense & Disaster Response"
    subhead="FEMA-approved. GSA-certified. Spec-compliant. Deploy rapidly, build with certainty. Trusted by military and government partners."
    image="/img/military-hero.jpg"
  />

  <!-- Why Government Chooses Modular -->
  <section class="py-section-y">
    <div class="container">
      <div class="max-w-3xl mx-auto mb-12 text-center">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Why Modular for Military & Government</h2>
        <p class="text-lg text-ink-700 leading-relaxed">
          When speed matters, budgets are tight, and compliance is non-negotiable, modular construction delivers.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <div class="flex gap-6 items-start bg-white rounded-2xl p-8 shadow-soft">
          <div class="text-5xl flex-shrink-0">⚡</div>
          <div>
            <h3 class="text-xl font-bold text-ink-900 mb-2">Rapid Deployment</h3>
            <p class="text-ink-700">
              Factory-built modules deploy in weeks, not months. Pre-fabricated, tested, and ready for on-site assembly. Perfect for emergency response.
            </p>
          </div>
        </div>

        <div class="flex gap-6 items-start bg-white rounded-2xl p-8 shadow-soft">
          <div class="text-5xl flex-shrink-0">📋</div>
          <div>
            <h3 class="text-xl font-bold text-ink-900 mb-2">Full Compliance</h3>
            <p class="text-ink-700">
              IBC, FEMA, military spec, GSA schedule — built-in from design. Inspections and certifications complete before delivery.
            </p>
          </div>
        </div>

        <div class="flex gap-6 items-start bg-white rounded-2xl p-8 shadow-soft">
          <div class="text-5xl flex-shrink-0">💰</div>
          <div>
            <h3 class="text-xl font-bold text-ink-900 mb-2">Budget Certainty</h3>
            <p class="text-ink-700">
              Transparent, fixed pricing. No change orders. Cost-per-unit scales predictably with volume. All-in quotes with delivery and installation.
            </p>
          </div>
        </div>

        <div class="flex gap-6 items-start bg-white rounded-2xl p-8 shadow-soft">
          <div class="text-5xl flex-shrink-0">✓</div>
          <div>
            <h3 class="text-xl font-bold text-ink-900 mb-2">Quality Control</h3>
            <p class="text-ink-700">
              Factory-built precision. Every module inspected and tested. Zero field defects. Warranty-backed quality assurance.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Government Applications -->
  <section class="py-section-y bg-ink-50">
    <div class="container">
      <h2 class="text-4xl font-bold text-ink-900 mb-12 text-center">Government Applications</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white rounded-2xl p-8 border-l-4 border-brand-primary">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">🛡️ Military Base Housing</h3>
          <p class="text-ink-700 mb-6">
            Forward operating bases, training camps, and permanent installations. Modular delivers military-spec temporary and permanent facilities.
          </p>
          <ul class="space-y-2 text-sm text-ink-700">
            <li>✓ Military-grade construction standards</li>
            <li>✓ Quick assembly & disassembly</li>
            <li>✓ Scalable for base needs</li>
            <li>✓ Government contract experience</li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 border-l-4 border-brand-primary">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">🆘 Disaster Relief</h3>
          <p class="text-ink-700 mb-6">
            FEMA partnerships. Emergency housing for displaced families. Rapid deployment when communities need it most.
          </p>
          <ul class="space-y-2 text-sm text-ink-700">
            <li>✓ FEMA-approved housing</li>
            <li>✓ Emergency deployment specs</li>
            <li>✓ Government coordination</li>
            <li>✓ Rapid logistics</li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 border-l-4 border-brand-primary">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">🏥 Medical Facilities</h3>
          <p class="text-ink-700 mb-6">
            Mobile field hospitals, medical clinics, and triage facilities. Rapidly deployed for emergency response.
          </p>
          <ul class="space-y-2 text-sm text-ink-700">
            <li>✓ Medical facility configurations</li>
            <li>✓ Built-in utility systems</li>
            <li>✓ Quick setup and teardown</li>
            <li>✓ Sterile environment ready</li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 border-l-4 border-brand-primary">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">🌍 Infrastructure Projects</h3>
          <p class="text-ink-700 mb-6">
            Construction site housing, remote facility support, and infrastructure project logistics.
          </p>
          <ul class="space-y-2 text-sm text-ink-700">
            <li>✓ Worker camp configurations</li>
            <li>✓ Temporary admin offices</li>
            <li>✓ Storage & supply units</li>
            <li>✓ Remote location delivery</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications & Compliance -->
  <section class="py-section-y">
    <div class="container">
      <div class="max-w-3xl mx-auto mb-12 text-center">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Certifications & Standards</h2>
        <p class="text-lg text-ink-700">
          Built to govern standards from day one.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto mb-12">
        <div class="bg-brand-primary-50 rounded-2xl p-8">
          <h3 class="text-lg font-bold text-ink-900 mb-4">✓ International Standards</h3>
          <ul class="space-y-3 text-sm text-ink-700">
            <li>• International Building Code (IBC) compliant</li>
            <li>• FEMA-approved temporary housing</li>
            <li>• Military construction standards</li>
            <li>• Transportation DOT-certified</li>
          </ul>
        </div>

        <div class="bg-brand-primary-50 rounded-2xl p-8">
          <h3 class="text-lg font-bold text-ink-900 mb-4">✓ Government Contracting</h3>
          <ul class="space-y-3 text-sm text-ink-700">
            <li>• GSA schedule available</li>
            <li>• Government procurement ready</li>
            <li>• Federal acquisition experience</li>
            <li>• Disaster agency coordination</li>
          </ul>
        </div>
      </div>

      <div class="bg-white rounded-2xl p-8 border-2 border-brand-primary max-w-3xl mx-auto text-center">
        <p class="text-ink-700 mb-4">
          <strong>50+ completed projects</strong> with government agencies, military installations, and disaster response teams.
        </p>
        <p class="text-ink-700">
          <strong>Zero compliance issues.</strong> Every project meets or exceeds applicable standards.
        </p>
      </div>
    </div>
  </section>

  <!-- Rapid Deployment Capability -->
  <section class="py-section-y bg-ink-50">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Rapid Deployment Scenarios</h2>
        <p class="text-lg text-ink-700">
          From concept to on-site assembly in weeks, not months.
        </p>
      </div>

      <div class="max-w-3xl mx-auto space-y-6">
        <div class="bg-white rounded-2xl p-8">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Emergency Housing Response</h3>
          <p class="text-ink-700 mb-6">
            Disaster strikes. Families are displaced. Modular units deploy in 2–4 weeks to provide safe, dignified shelter while rebuilding begins.
          </p>
          <p class="text-sm text-ink-600">
            <strong>Timeline:</strong> site assessment → module delivery → assembly → occupancy (weeks 1–4)
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Military Base Installation</h3>
          <p class="text-ink-700 mb-6">
            New base activation. Temporary housing needed for personnel. Modules arrive pre-fabricated, tested, and ready for quick assembly.
          </p>
          <p class="text-sm text-ink-600">
            <strong>Timeline:</strong> specifications → fabrication → delivery → installation (weeks 6–12)
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8">
          <h3 class="text-2xl font-bold text-ink-900 mb-4">Infrastructure Project Support</h3>
          <p class="text-ink-700 mb-6">
            Large construction project. Remote location. Worker housing needed on-site. Modular deployment supports project timelines and logistical needs.
          </p>
          <p class="text-sm text-ink-600">
            <strong>Timeline:</strong> RFQ → design → fabrication → delivery → assembly (weeks 8–16)
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Logistical Coordination -->
  <section class="py-section-y">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-4xl font-bold text-ink-900 mb-4">Logistical Mastery</h2>
        <p class="text-lg text-ink-700">
          We handle the complex coordination so you can focus on the mission.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl p-8 shadow-soft">
          <h3 class="text-lg font-bold text-ink-900 mb-3">🚚 Delivery Fleet</h3>
          <p class="text-ink-700">
            We own and operate our delivery fleet. Nationwide coordination. Remote location access. On-time arrival is our commitment.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-soft">
          <h3 class="text-lg font-bold text-ink-900 mb-3">👥 Installation Teams</h3>
          <p class="text-ink-700">
            Experienced crews handle on-site assembly. Full systems startup and testing. Handoff to your team with complete documentation.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-soft">
          <h3 class="text-lg font-bold text-ink-900 mb-3">📅 Coordination</h3>
          <p class="text-ink-700">
            We coordinate with your teams, contractors, and government agencies. Regular updates. Transparent timelines. No surprises.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-soft">
          <h3 class="text-lg font-bold text-ink-900 mb-3">⚙️ Technical Support</h3>
          <p class="text-ink-700">
            Post-deployment support. Spare parts availability. Maintenance guidance. Long-term partnership beyond initial installation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact for Government -->
  <section class="py-section-y bg-brand-primary-50">
    <div class="container">
      <div class="max-w-3xl mx-auto bg-white rounded-2xl p-8 md:p-12 text-center shadow-large">
        <h2 class="text-3xl md:text-4xl font-bold text-ink-900 mb-6">Ready to Deploy?</h2>
        <p class="text-lg text-ink-700 mb-8">
          For government agencies, FEMA partnerships, military inquiries, or emergency deployment needs, contact Dylan directly for rapid response.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+14056591949" class="inline-flex items-center justify-center gap-2 rounded-lg bg-brand-primary text-white px-8 py-4 font-semibold hover:shadow-lg transition">
            <span>📞</span>
            Call (405) 659-1949
          </a>
          <a href="mailto:Dylan.Walker@saltgrassmodular.com" class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-brand-primary text-brand-primary px-8 py-4 font-semibold hover:bg-brand-primary-50 transition">
            <span>✉️</span>
            Email Dylan
          </a>
        </div>
      </div>
    </div>
  </section>

  <CtaBanner
    headline="Government & Military Solutions"
    subhead="Saltgrass is ready to support your mission. Fast deployment, spec compliance, budget certainty."
  />
</BaseLayout>
