---

<BaseLayout
  title="Projects & Case Studies - SaltGrass Modular"
  description="Browse completed SaltGrass Modular projects. Homes, pools, and developments built and delivered."
>
  <Hero
    eyebrow="Our Work"
    headline="Completed Projects"
    subhead="Real homes. Real clients. Real results. From single residences to multi-unit developments and luxury pools."
    image="/img/projects/640-sf-container-home-alamosa-colorado-exterior-2.webp"
  />

  <!-- Project Gallery -->
  <section class="py-section-y">
    <div class="container">
      <h2 class="text-4xl font-bold text-ink-900 mb-12 text-center">Gallery</h2>

      <!-- Category Filter Buttons -->
      <div class="flex flex-wrap justify-center gap-4 mb-12">
        {categories.map(cat => (
          <button
            class={`px-6 py-2 rounded-lg font-semibold transition ${
              cat.id === 'all'
                ? 'bg-brand-primary text-white'
                : 'bg-ink-50 text-ink-900 hover:bg-ink-100'
            }`}
            onclick={`filterProjects('${cat.id}')`}
            data-category={cat.id}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- Projects Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map(project => (
          <div class={`project-card bg-white rounded-2xl overflow-hidden shadow-soft hover:shadow-large transition`} data-category={project.category}>
            {/* Image */}
            <img src={project.image} alt={`${project.name} — ${project.subtitle}`} loading="lazy" class="h-48 w-full object-cover" />

            {/* Content */}
            <div class="p-6">
              <p class="text-xs font-bold text-brand-primary uppercase tracking-wide mb-2">
                {project.type}
              </p>
              <h3 class="text-2xl font-bold text-ink-900 mb-1">{project.name}</h3>
              <p class="text-sm text-ink-600 mb-4">{project.subtitle}</p>

              {/* Quick Details */}
              <div class="grid grid-cols-2 gap-4 mb-6 pb-6 border-b border-ink-200">
                {project.details.map(detail => (
                  <div>
                    <p class="text-xs text-ink-600">{detail.label}</p>
                    <p class="font-bold text-ink-900">{detail.value}</p>
                  </div>
                ))}
              </div>

              {/* Description */}
              <p class="text-sm text-ink-700 mb-4">{project.description}</p>

              {/* Testimonial — tinted inner panel (nested inside the white project card) */}
              <div class="bg-ink-50 rounded-lg p-4 mb-6">
                <p class="text-xs text-ink-700 italic">{project.testimonial}</p>
              </div>

              {/* CTA */}
              <button class="w-full btn-secondary text-sm">See Details</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Case Study Highlights -->
  <section class="py-section-y bg-ink-50">
    <div class="container">
      <h2 class="text-4xl font-bold text-ink-900 mb-12 text-center">Project Statistics</h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 max-w-4xl mx-auto">
        <div class="bg-white rounded-xl p-6 text-center">
          <p class="text-4xl font-bold text-brand-primary mb-2">50+</p>
          <p class="font-semibold text-ink-900">Projects Delivered</p>
          <p class="text-sm text-ink-600">And counting</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center">
          <p class="text-4xl font-bold text-brand-primary mb-2">99%</p>
          <p class="font-semibold text-ink-900">Client Satisfaction</p>
          <p class="text-sm text-ink-600">On-time delivery</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center">
          <p class="text-4xl font-bold text-brand-primary mb-2">8–9</p>
          <p class="font-semibold text-ink-900">Month Average</p>
          <p class="text-sm text-ink-600">Design to move-in</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center">
          <p class="text-4xl font-bold text-brand-primary mb-2">0</p>
          <p class="font-semibold text-ink-900">Warranty Issues</p>
          <p class="text-sm text-ink-600">Factory-built quality</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Industry Recognition -->
  <section class="py-section-y">
    <div class="container">
      <h2 class="text-3xl font-bold text-ink-900 mb-8 text-center">Why Our Projects Stand Out</h2>
      <div class="max-w-3xl mx-auto space-y-6">
        <div class="flex gap-4">
          <div class="text-5xl flex-shrink-0">🏆</div>
          <div>
            <h3 class="text-lg font-bold text-ink-900 mb-2">Quality First</h3>
            <p class="text-ink-700">
              Every project is factory-inspected and tested before leaving our facility. On-site installation is handled by certified technicians.
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="text-5xl flex-shrink-0">⏰</div>
          <div>
            <h3 class="text-lg font-bold text-ink-900 mb-2">On-Time, Every Time</h3>
            <p class="text-ink-700">
              Modular construction means predictable timelines. Weather delays and supply chain issues don't affect our schedule like they do traditional builds.
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="text-5xl flex-shrink-0">💬</div>
          <div>
            <h3 class="text-lg font-bold text-ink-900 mb-2">Transparent Communication</h3>
            <p class="text-ink-700">
              Regular updates, clear timelines, honest pricing. No surprises. Our clients know exactly what to expect and when to expect it.
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="text-5xl flex-shrink-0">🎯</div>
          <div>
            <h3 class="text-lg font-bold text-ink-900 mb-2">Custom to Your Needs</h3>
            <p class="text-ink-700">
              Every project is customized. We listen to your vision and deliver exactly what you asked for—no cookie-cutter solutions.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CtaBanner
    headline="Your Project Could Be Next"
    subhead="Start your journey. Get a free consultation and see how modular can work for you."
  />
</BaseLayout>

<script>
  function filterProjects(category) {
    // Update button styles
    document.querySelectorAll('[data-category]').forEach(btn => {
      btn.classList.remove('bg-brand-primary', 'text-white');
      btn.classList.add('bg-ink-50', 'text-ink-900');
    });
    event.target.classList.add('bg-brand-primary', 'text-white');
    event.target.classList.remove('bg-ink-50', 'text-ink-900');

    // Filter projects
    document.querySelectorAll('.project-card').forEach(card => {
      if (category === 'all' || card.dataset.category === category) {
        card.style.display = 'block';
      } else {
        card.style.display = 'none';
      }
    });
  }
</script>
