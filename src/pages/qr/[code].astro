---
// On-demand route — resolves arbitrary QR codes at request time via the
// LPAI backend, which logs the click + returns the destination URL.
export const prerender = false;

const API_BASE = import.meta.env.PUBLIC_API_URL || 'https://lpai-monorepo-production.up.railway.app';
const LOCATION_ID = import.meta.env.PUBLIC_LOCATION_ID;
const { code } = Astro.params;

try {
  const res = await fetch(`${API_BASE}/api/qr/${encodeURIComponent(code)}?locationId=${LOCATION_ID}`);
  if (res.ok) {
    const json = await res.json();
    const dest = json.redirectUrl || json.url || json.data?.redirectUrl;
    if (dest) {
      return Astro.redirect(dest, 302);
    }
  }
} catch {
  // Fall through to 404
}

return new Response('QR code not found', { status: 404 });
---
