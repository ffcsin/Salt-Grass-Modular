---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import ServicesGrid from '../components/sections/ServicesGrid.astro';
import StatsStrip from '../components/sections/StatsStrip.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';

const heroImage = '/img/projects/640-sf-container-home-alamosa-colorado-exterior.webp';
const heroHeadline = 'Custom Modular Homes Built Your Way';
const heroSubheading = 'From Oklahoma to the World. We listen. We design. We build. Whether you\'re an individual homeowner, a developer scaling units, or a government agency, SaltGrass delivers outside-the-box modular solutions with precision and care.';

const stats = [
  { value: '3+', label: 'Years in Business' },
  { value: '50+', label: 'Projects Delivered' },
  { value: '99%', label: 'Client Satisfaction' },
  { value: 'USA', label: 'Service Area' },
];
---

<BaseLayout
  title="Home"
  description="Custom modular homes, pools, and rapid deployment housing. Built in Oklahoma, serving the USA."
>
  <Hero
    showLogo
    eyebrow="Modular Construction"
    headline={heroHeadline}
    subhead={heroSubheading}
    primaryCta={{ label: 'Explore Our Services', href: '/services' }}
    secondaryCta={{ label: 'Request a Quote', href: '#', dataAction: 'quote-modal' }}
    image={heroImage}
  />

  <ServicesGrid />

  <StatsStrip stats={stats} />

  <CtaBanner
    headline="Ready to start your modular project?"
    subhead="Get a free consultation and transparent quote."
  />

</BaseLayout>
