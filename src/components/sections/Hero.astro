---
interface Props {
  eyebrow?: string;
  headline: string;
  subhead: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string; dataAction?: string };
  image?: string;
}

const { eyebrow, headline, subhead, primaryCta, secondaryCta, image = '/img/hero-default.jpg' } = Astro.props;
---

<section class="py-section-y-lg relative overflow-hidden">
  <div class="container mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 items-center">
      {/* Text content */}
      <div class="order-2 md:order-1">
        {eyebrow && (
          <span class="inline-block text-sm font-bold text-brand-primary uppercase tracking-wide mb-4">
            {eyebrow}
          </span>
        )}
        <h1 class="text-5xl md:text-6xl font-bold text-ink-900 mb-6 leading-tight">
          {headline}
        </h1>
        <p class="text-lg md:text-xl text-ink-700 mb-8 leading-relaxed">
          {subhead}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          {primaryCta && (
            <a href={primaryCta.href} class="btn-primary text-center">
              {primaryCta.label}
            </a>
          )}
          {secondaryCta && (
            <a
              href={secondaryCta.href}
              class="btn-secondary text-center"
              data-action={secondaryCta.dataAction}
            >
              {secondaryCta.label}
            </a>
          )}
        </div>
      </div>

      {/* Hero image */}
      <div class="order-1 md:order-2 relative h-96 md:h-full rounded-2xl overflow-hidden shadow-xl bg-ink-100">
        <img
          src={image}
          alt={headline}
          width={800}
          height={600}
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </div>
</section>
