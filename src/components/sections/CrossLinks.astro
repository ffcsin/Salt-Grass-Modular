---
// Internal-linking module — every content page renders one of these to weave the
// clusters together (location → cost → services → comparisons → financing).
interface LinkItem { label: string; href: string }
interface Props {
  heading?: string;
  links: LinkItem[];
}
const { heading = 'Explore More', links } = Astro.props;
---

{links.length > 0 && (
  <section class="py-section-y-sm">
    <div class="container max-w-5xl">
      <h2 class="text-2xl font-bold text-ink-900 mb-6">{heading}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {links.map((l) => (
          <a href={l.href} class="block rounded-xl border border-ink-200 bg-white p-5 hover:border-brand-primary hover:shadow-medium transition group">
            <span class="font-semibold text-ink-900 group-hover:text-brand-primary transition-colors">{l.label}</span>
            <span class="text-brand-primary ml-1" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
