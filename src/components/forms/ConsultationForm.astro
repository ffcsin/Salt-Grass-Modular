---
const API_BASE = import.meta.env.PUBLIC_API_URL || 'https://lpai-monorepo-production.up.railway.app';
const LOCATION_ID = import.meta.env.PUBLIC_LOCATION_ID || 'plan_chNIQv7tfy09Ew_h1liV';
---

<form id="consultation-form" data-location-id={LOCATION_ID} class="space-y-4">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <label for="firstName" class="block text-sm font-semibold text-ink-900 mb-2">
        First Name <span class="text-brand-primary">*</span>
      </label>
      <input
        id="firstName"
        name="firstName"
        type="text"
        placeholder="John"
        required
        class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-primary"
      />
    </div>
    <div>
      <label for="lastName" class="block text-sm font-semibold text-ink-900 mb-2">
        Last Name <span class="text-brand-primary">*</span>
      </label>
      <input
        id="lastName"
        name="lastName"
        type="text"
        placeholder="Smith"
        required
        class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-primary"
      />
    </div>
  </div>

  <div>
    <label for="email" class="block text-sm font-semibold text-ink-900 mb-2">
      Email Address <span class="text-brand-primary">*</span>
    </label>
    <input
      id="email"
      name="email"
      type="email"
      placeholder="you@example.com"
      required
      class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-primary"
    />
  </div>

  <div>
    <label for="phone" class="block text-sm font-semibold text-ink-900 mb-2">
      Phone Number <span class="text-brand-primary">*</span>
    </label>
    <input
      id="phone"
      name="phone"
      type="tel"
      placeholder="(405) 555-0123"
      required
      class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-primary"
    />
  </div>

  <div>
    <label for="serviceInterest" class="block text-sm font-semibold text-ink-900 mb-2">
      Service of Interest <span class="text-brand-primary">*</span>
    </label>
    <select
      id="serviceInterest"
      name="serviceInterest"
      required
      class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-primary"
    >
      <option value="">Select a service…</option>
      <option value="Container Homes">Container Homes</option>
      <option value="Traditional Builds">Traditional Builds</option>
      <option value="Modular Pools">Modular Pools</option>
      <option value="Disaster Relief">Disaster Relief</option>
      <option value="Military Housing">Military Housing</option>
      <option value="Other">Other</option>
    </select>
  </div>

  <div>
    <label for="currentSituation" class="block text-sm font-semibold text-ink-900 mb-2">
      Tell us about your project <span class="text-brand-primary">*</span>
    </label>
    <textarea
      id="currentSituation"
      name="currentSituation"
      rows="4"
      placeholder="What are you looking to build or explore?"
      required
      class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-primary"
    ></textarea>
  </div>

  <div>
    <label for="preferredContact" class="block text-sm font-semibold text-ink-900 mb-2">
      Preferred Contact Method <span class="text-brand-primary">*</span>
    </label>
    <select
      id="preferredContact"
      name="preferredContact"
      required
      class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-primary"
    >
      <option value="">Select…</option>
      <option value="Phone Call">Phone Call</option>
      <option value="Email">Email</option>
      <option value="Video Call">Video Call</option>
    </select>
  </div>

  <!-- Honeypot -->
  <input
    name="website_url"
    type="text"
    tabindex="-1"
    autocomplete="off"
    style="position:absolute;left:-9999px;opacity:0;pointer-events:none"
    aria-hidden="true"
  />

  <div id="consultation-error" class="hidden text-sm text-red-600 bg-red-50 p-3 rounded-lg"></div>

  <button
    type="submit"
    class="btn-primary w-full"
  >
    Book Consultation
  </button>

  <div id="consultation-success" class="hidden text-center py-6">
    <div class="text-4xl mb-3">✓</div>
    <h4 class="text-lg font-semibold text-ink-900 mb-2">Consultation Requested</h4>
    <p class="text-ink-700">We'll reach out shortly to schedule your call with Dylan.</p>
  </div>
</form>

<script define:vars={{ API_BASE, LOCATION_ID }}>
  const form = document.getElementById('consultation-form');
  const errEl = document.getElementById('consultation-error');
  const successEl = document.getElementById('consultation-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);

    // Honeypot check
    if (fd.get('website_url')) {
      form.classList.add('hidden');
      successEl.classList.remove('hidden');
      return;
    }

    const data = {};
    for (const [k, v] of fd.entries()) {
      if (k === 'website_url') continue;
      data[k] = v;
    }

    errEl.classList.add('hidden');

    try {
      const res = await fetch(`${API_BASE}/api/portal/forms/consultation/submit`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          locationId: LOCATION_ID,
          data,
          meta: { referrer: document.referrer },
        }),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.message || 'Could not book consultation');
      }

      form.classList.add('hidden');
      successEl.classList.remove('hidden');
    } catch (err) {
      errEl.textContent = err.message;
      errEl.classList.remove('hidden');
    }
  });
</script>
