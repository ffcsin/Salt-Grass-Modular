---
// SaltGrass Modular — Developer / Government RFQ form.
//
// Submits to the SAME LPAI v2 website-clients forms endpoint as the quote form
// (POST /api/v2/website-clients/forms/submit), which runs the full 5-layer
// bot-protection envelope (honeypot + time-trap + Redis rate-limit +
// disposable-email + optional Turnstile) AND upserts a CRM contact/lead +
// notifies the partner. Subject is tagged "Developer / Government RFQ" so the
// BE subject-triage routes it correctly. (Previously hit the older
// /api/portal/forms/rfq/submit endpoint, which only created a contact if an
// `rfq` website_forms doc was configured — this removes that dependency.)
const API_BASE = import.meta.env.PUBLIC_API_URL || 'https://lpai-monorepo-production.up.railway.app';
const LOCATION_ID = import.meta.env.PUBLIC_LOCATION_ID || 'plan_chNIQv7tfy09Ew_h1liV';
const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY || '';
---

<form id="rfq-form" data-location-id={LOCATION_ID} class="space-y-4">
  <div>
    <label for="companyName" class="block text-sm font-semibold text-ink-900 mb-2">
      Company Name <span class="text-brand-primary">*</span>
    </label>
    <input
      id="companyName"
      name="companyName"
      type="text"
      placeholder="Your company name"
      required
      class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-primary"
    />
  </div>

  <div>
    <label for="contactPerson" class="block text-sm font-semibold text-ink-900 mb-2">
      Contact Person <span class="text-brand-primary">*</span>
    </label>
    <input
      id="contactPerson"
      name="contactPerson"
      type="text"
      placeholder="Your name"
      required
      class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-primary"
    />
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <label for="email" class="block text-sm font-semibold text-ink-900 mb-2">
        Business Email <span class="text-brand-primary">*</span>
      </label>
      <input
        id="email"
        name="email"
        type="email"
        placeholder="you@company.com"
        required
        class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-primary"
      />
    </div>
    <div>
      <label for="phone" class="block text-sm font-semibold text-ink-900 mb-2">
        Phone Number <span class="text-brand-primary">*</span>
      </label>
      <input
        id="phone"
        name="phone"
        type="tel"
        placeholder="(405) 555-0123"
        required
        class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-primary"
      />
    </div>
  </div>

  <div>
    <label for="projectScope" class="block text-sm font-semibold text-ink-900 mb-2">
      Project Scope <span class="text-brand-primary">*</span>
    </label>
    <textarea
      id="projectScope"
      name="projectScope"
      rows="5"
      placeholder="Describe your development or construction needs..."
      required
      class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-primary"
    ></textarea>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <label for="unitQuantity" class="block text-sm font-semibold text-ink-900 mb-2">
        Number of Units
      </label>
      <input
        id="unitQuantity"
        name="unitQuantity"
        type="number"
        placeholder="e.g., 50"
        class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-primary"
      />
    </div>
    <div>
      <label for="timeline" class="block text-sm font-semibold text-ink-900 mb-2">
        Delivery Timeline <span class="text-brand-primary">*</span>
      </label>
      <select
        id="timeline"
        name="timeline"
        required
        class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-primary"
      >
        <option value="">Select…</option>
        <option value="Q1 2027">Q1 2027</option>
        <option value="Q2 2027">Q2 2027</option>
        <option value="Q3 2027">Q3 2027</option>
        <option value="Q4 2027">Q4 2027</option>
        <option value="TBD">TBD</option>
      </select>
    </div>
  </div>

  <div>
    <label for="referralSource" class="block text-sm font-semibold text-ink-900 mb-2">
      How did you hear about us?
    </label>
    <select
      id="referralSource"
      name="referralSource"
      class="w-full px-4 py-2 border border-ink-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-primary"
    >
      <option value="">Select…</option>
      <option value="Google">Google</option>
      <option value="Industry Contact">Industry Contact</option>
      <option value="LinkedIn">LinkedIn</option>
      <option value="Trade Show">Trade Show</option>
      <option value="Other">Other</option>
    </select>
  </div>

  {/* Bot-protection envelope (LPAI 5-layer). _renderedAt is stamped client-side on load. */}
  <input type="hidden" name="_renderedAt" value="" />
  <input
    type="email"
    name="_hp_email"
    tabindex="-1"
    autocomplete="off"
    aria-hidden="true"
    style="position:absolute;left:-9999px;opacity:0;pointer-events:none;height:0;width:0"
  />
  {TURNSTILE_SITE_KEY && (
    <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="light" data-size="flexible"></div>
  )}

  <div id="rfq-error" class="hidden text-sm text-red-600 bg-red-50 p-3 rounded-lg"></div>

  <button
    type="submit"
    class="btn-primary w-full"
  >
    Submit RFQ
  </button>

  <div id="rfq-success" class="hidden text-center py-6">
    <div class="text-4xl mb-3">✓</div>
    <h4 class="text-lg font-semibold text-ink-900 mb-2">RFQ Received</h4>
    <p class="text-ink-700">Our team will review your request and contact you shortly.</p>
  </div>
</form>

{TURNSTILE_SITE_KEY && (
  <script is:inline async defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>
)}

<script define:vars={{ API_BASE, LOCATION_ID }}>
  const form = document.getElementById('rfq-form');
  const errEl = document.getElementById('rfq-error');
  const successEl = document.getElementById('rfq-success');
  const renderedAtEl = form?.querySelector('input[name="_renderedAt"]');
  // Time-trap baseline: stamp on page load so the BE measures load→submit.
  if (renderedAtEl) renderedAtEl.value = new Date().toISOString();

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);

    // Honeypot — bots fill it; short-circuit to a fake success.
    if ((fd.get('_hp_email') || '').toString().trim()) {
      form.classList.add('hidden');
      successEl?.classList.remove('hidden');
      return;
    }

    const get = (k) => (fd.get(k) || '').toString().trim();
    const company = get('companyName');
    const fullName = get('contactPerson') || company || 'Developer Lead';
    const message = [
      get('projectScope') || 'Developer / Government RFQ from the website.',
      '',
      `Company: ${company || '—'}`,
      `Units: ${get('unitQuantity') || '—'}`,
      `Delivery timeline: ${get('timeline') || '—'}`,
      `Heard via: ${get('referralSource') || '—'}`,
    ].join('\n').slice(0, 1990);

    const turnstileToken =
      (form.querySelector('input[name="cf-turnstile-response"]') || {}).value || '';

    errEl?.classList.add('hidden');
    const btn = form.querySelector('button[type="submit"]');
    const origLabel = btn ? btn.textContent : '';
    if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }

    try {
      const res = await fetch(`${API_BASE}/api/v2/website-clients/forms/submit`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          locationId: LOCATION_ID,
          formId: 'rfq',
          locale: 'en',
          fields: {
            fullName,
            email: get('email'),
            phone: get('phone') || undefined,
            subject: 'Developer / Government RFQ',
            message,
          },
          _hp_email: (fd.get('_hp_email') || '').toString(),
          _renderedAt: (renderedAtEl && renderedAtEl.value) || new Date().toISOString(),
          turnstileToken,
        }),
      });

      let data = {};
      try { data = await res.json(); } catch { /* non-JSON edge */ }

      if (!res.ok) {
        let msg = Array.isArray(data.message) ? data.message.join(', ') : (data.message || 'Could not submit RFQ.');
        if (res.status === 429) {
          msg = "You've sent a few requests in a short time. Please try again in a bit.";
        } else if (typeof msg === 'string' && (msg.includes('time-trap') || msg.includes('too fast'))) {
          msg = 'That was a little too fast — please try once more.';
        } else if (typeof msg === 'string' && msg.toLowerCase().includes('turnstile')) {
          msg = 'Verification failed. Please refresh the page and try again.';
        } else if (typeof msg === 'string' && msg.toLowerCase().includes('disposable')) {
          msg = 'Please use a non-disposable business email so our team can reply.';
        }
        throw new Error(msg);
      }

      form.classList.add('hidden');
      successEl?.classList.remove('hidden');
    } catch (err) {
      if (errEl) { errEl.textContent = err.message; errEl.classList.remove('hidden'); }
      if (btn) { btn.disabled = false; btn.textContent = origLabel; }
    }
  });
</script>
