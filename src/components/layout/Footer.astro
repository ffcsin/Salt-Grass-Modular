---
import { STATE_LOCATIONS, METRO_LOCATIONS } from '../../data/locations';

// Curated footer subsets (not all 50 states) for the internal-linking backbone.
const featuredStates = STATE_LOCATIONS
  .filter((s) => ['oklahoma', 'texas', 'colorado', 'kansas', 'arkansas', 'missouri'].includes(s.slug))
  .sort((a, b) => a.name.localeCompare(b.name));
const featuredMetros = METRO_LOCATIONS
  .filter((m) => ['oklahoma-city', 'tulsa', 'dallas', 'houston', 'denver'].includes(m.slug))
  .sort((a, b) => a.name.localeCompare(b.name));
---

<footer class="bg-brand-secondary text-ink-200">
  <div class="container py-section-y grid gap-12 md:grid-cols-4">
    <div>
      <img src="/img/logo-saltgrass.webp" alt="SaltGrass Modular" width="198" height="140" class="h-32 w-auto rounded-xl bg-white px-4 py-3 mb-4 object-contain" />
      <p class="text-[0.95rem] leading-relaxed mb-4 text-ink-100">Custom modular solving housing crisis across the USA. Modular homes, pools, and rapid deployment solutions.</p>
      <address class="not-italic text-sm space-y-1">
        <div>Oklahoma, USA</div>
        <a href="tel:405-659-1949" class="hover:text-white block">405-659-1949</a>
        <a href="mailto:dylan@saltgrassmodular.com" class="hover:text-white block">dylan@saltgrassmodular.com</a>
      </address>
    </div>

    <div>
      <h4 class="text-white font-semibold mb-4">Services</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/services/container-homes" class="hover:text-white transition-colors">Container Homes</a></li>
        <li><a href="/services/traditional-builds" class="hover:text-white transition-colors">Traditional Builds</a></li>
        <li><a href="/services/pools" class="hover:text-white transition-colors">Modular Pools</a></li>
        <li><a href="/services/disaster-relief" class="hover:text-white transition-colors">Disaster Relief</a></li>
        <li><a href="/services/developers" class="hover:text-white transition-colors">Developers &amp; Military</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-white font-semibold mb-4">Service Areas</h4>
      <ul class="space-y-2 text-sm">
        {featuredMetros.map((m) => (
          <li><a href={`/locations/${m.slug}`} class="hover:text-white transition-colors">{m.name}, {m.stateAbbr}</a></li>
        ))}
        {featuredStates.slice(0, 3).map((s) => (
          <li><a href={`/locations/${s.slug}`} class="hover:text-white transition-colors">{s.name}</a></li>
        ))}
        <li><a href="/locations" class="hover:text-white font-semibold transition-colors">All Service Areas →</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-white font-semibold mb-4">Guides & Company</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/saltgrass-101" class="hover:text-white transition-colors">SaltGrass 101</a></li>
        <li><a href="/compare" class="hover:text-white transition-colors">Guides & Comparisons</a></li>
        <li><a href="/glossary" class="hover:text-white transition-colors">Glossary</a></li>
        <li><a href="/saltgrass-101/cost-breakdown" class="hover:text-white transition-colors">Pricing</a></li>
        <li><a href="/financing" class="hover:text-white transition-colors">Financing</a></li>
        <li><a href="/about" class="hover:text-white transition-colors">About</a></li>
        <li><a href="/projects" class="hover:text-white transition-colors">Projects</a></li>
        <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10 py-6">
    <div class="container flex flex-col sm:flex-row items-center justify-between gap-3 text-xs">
      <span>© 2026 SaltGrass Modular. All rights reserved.</span>
      <span class="text-ink-400">
        Powered by <a href="https://leadprospecting.ai" target="_blank" rel="noopener" class="hover:text-white underline">LeadProspecting.AI</a>
      </span>
      <div class="flex gap-4">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-white transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style>
  /* The global `a` rule paints links crimson (text-brand-primary) — unreadable
     on the dark ink-900 footer. Override to a light neutral (matching the dark
     header's ink-200 links) with white on hover.
     ink-200 (#E2E8F0) on ink-900 (#0F172A) ≈ 13:1 contrast (WCAG AAA). */
  footer a { color: #E2E8F0; }
  footer a:hover { color: #ffffff; }
  /* Keep section headings + the brand mark crisp white. */
  footer h3, footer h4 { color: #ffffff; }
</style>
