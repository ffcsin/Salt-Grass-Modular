---
import '@fontsource-variable/inter';
import '../../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro';

const { title, description, keywords, ogImage, noindex = false } = Astro.props;
const siteUrl = import.meta.env.SITE || 'https://saltgrass-modular.vercel.app';
const fullTitle = title === 'Home' ? 'Saltgrass Modular | Custom Container Homes & Modular Construction' : `${title} | Saltgrass Modular`;
const metaDescription = description || 'Custom modular homes, pools, and rapid deployment housing solutions built in Oklahoma.';
const metaImage = ogImage || `${siteUrl}/img/og-default.jpg`;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="preload" as="font" type="font/woff2"
          href="/fonts/inter-variable.woff2" crossorigin />

    <!-- Preload OG image for faster social embeds -->
    {metaImage && <link rel="preload" as="image" href={metaImage} />}

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={metaImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={metaImage} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#C41E3A" />

    <!-- Sentry error tracking (production monitoring) -->
    <script
      src="https://browser.sentry-cdn.com/7.99.0/bundle.min.js"
      integrity="sha384-+a3D8QgjOKQvx8qd1//DUpwGaVusJEW3KqKFv4RbWHd8VE6VYQ3EUNBtjFh1aVZ9h"
      crossorigin="anonymous"
      defer
    ></script>
    <script is:inline>
      if (window.Sentry) {
        window.Sentry.init({
          dsn: import.meta.env.PUBLIC_SENTRY_DSN || '',
          environment: 'production',
          tracesSampleRate: 0.1,
          replaysSessionSampleRate: 0.05,
          replaysOnErrorSampleRate: 1.0,
        });
      }
    </script>

    <!-- Organization & LocalBusiness Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Saltgrass Modular',
      url: siteUrl,
      logo: `${siteUrl}/logo.png`,
      description: 'Custom modular construction company specializing in container homes, pools, and rapid deployment housing.',
      telephone: '405-659-1949',
      email: 'Dylan.Walker@saltgrassmodular.com',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Wagner',
        addressLocality: 'Wagner',
        addressRegion: 'OK',
        postalCode: '73455',
        addressCountry: 'US',
      },
      sameAs: [],
      founder: {
        '@type': 'Person',
        name: 'Dylan Walker',
      },
    })} />

    <!-- LocalBusiness Schema (for Local SEO) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'LocalBusiness',
      name: 'Saltgrass Modular',
      image: metaImage,
      url: siteUrl,
      telephone: '405-659-1949',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Wagner',
        addressLocality: 'Wagner',
        addressRegion: 'OK',
        postalCode: '73455',
        addressCountry: 'US',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: '35.7929',
        longitude: '-98.7829',
      },
      areaServed: {
        '@type': 'Country',
        name: 'US',
      },
      priceRange: '$$',
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '4.9',
        reviewCount: '50',
      },
    })} />
  </head>
  <body>
    <a href="#main" class="skip-to-content">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <!-- LPAI Analytics Beacon (same-origin proxy to bypass ad blockers) -->
    <script async src="/api/s"></script>
  </body>
</html>
