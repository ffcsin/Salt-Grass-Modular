---
import '@fontsource-variable/inter';
import '../../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { SITE } from '../../lib/site-config';
import { localBusinessSchema, organizationSchema, webSiteSchema, breadcrumbSchema } from '../../lib/seo';

const {
  title,
  description,
  keywords,
  ogImage,
  noindex = false,
  // Page-specific JSON-LD objects (FAQ, Service, comparison, glossary, etc.)
  schemas = [],
  // [{name,url}] → rendered as BreadcrumbList schema
  breadcrumbs = [],
} = Astro.props;

const siteUrl = SITE.url;
// Strip any brand suffix a page may have baked into its own title so the
// template adds "| SaltGrass Modular" exactly once (no double-branding).
const cleanTitle = (title || '').replace(/\s*[-|]\s*SaltGrass Modular\s*$/i, '').trim();
const fullTitle = (title === 'Home' || !cleanTitle)
  ? `${SITE.brand} | ${SITE.tagline}`
  : `${cleanTitle} | ${SITE.brand}`;
const metaDescription = description || SITE.description;
const metaImage = ogImage || `${siteUrl}${SITE.ogImage}`;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const keywordStr = Array.isArray(keywords) ? keywords.join(', ') : keywords;

// Site-wide schema set (every page) + optional breadcrumb + page-specific schemas.
const allSchemas = [
  organizationSchema(),
  localBusinessSchema(),
  webSiteSchema(),
  ...(breadcrumbs.length ? [breadcrumbSchema(breadcrumbs)] : []),
  ...schemas,
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    {keywordStr && <meta name="keywords" content={keywordStr} />}
    <link rel="canonical" href={canonicalUrl} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

    {/* Geo tags — help local SEO + ground AI answers in the right geography */}
    <meta name="geo.region" content="US-OK" />
    <meta name="geo.placename" content="Oklahoma City, Oklahoma" />
    <meta name="geo.position" content="35.4676;-97.5164" />
    <meta name="ICBM" content="35.4676, -97.5164" />

    {/* Inter Variable is bundled + self-hosted via `@fontsource-variable/inter`
        (imported above); Astro emits its woff2 into /_astro with a content hash,
        so there is no stable path to hand-preload. A hardcoded /fonts/*.woff2
        preload here would 404. If font-load becomes the LCP bottleneck, copy the
        woff2 into public/fonts and preload that exact file. */}

    {/* No OG-image preload: og:image is only fetched by social crawlers from
        the meta tag below, never rendered on-page, so preloading it just wastes
        real users' bandwidth. The per-page LCP hero <img> carries
        fetchpriority="high" + loading="eager" in Hero.astro instead. */}

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={metaImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={metaImage} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#C41E3A" />

    <!-- Sentry error tracking (production monitoring) -->
    <script
      src="https://browser.sentry-cdn.com/7.99.0/bundle.min.js"
      integrity="sha384-+a3D8QgjOKQvx8qd1//DUpwGaVusJEW3KqKFv4RbWHd8VE6VYQ3EUNBtjFh1aVZ9h"
      crossorigin="anonymous"
      defer
    ></script>
    <script is:inline>
      if (window.Sentry) {
        window.Sentry.init({
          dsn: import.meta.env.PUBLIC_SENTRY_DSN || '',
          environment: 'production',
          tracesSampleRate: 0.1,
          replaysSessionSampleRate: 0.05,
          replaysOnErrorSampleRate: 1.0,
        });
      }
    </script>

    {/* JSON-LD: site-wide Organization + LocalBusiness + WebSite, plus any
        breadcrumb + page-specific schemas (FAQ, Service, DefinedTermSet, …).
        All built from the central seo.ts helpers — no per-page drift.
        (Removed the prior hardcoded aggregateRating 4.9/50 — unverified review
        counts are fabricated review schema and risk a Google penalty.) */}
    {allSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <a href="#main" class="skip-to-content">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <!-- LPAI Analytics Beacon (same-origin proxy to bypass ad blockers) -->
    <script async src="/api/s"></script>
  </body>
</html>
